# ─────────────────────────────────────────────────────────
#  Claim Analytics Platform — Environment Variables
#  Copy to .env and adjust values for your deployment
# ─────────────────────────────────────────────────────────

# Node server
NODE_ENV=production
PORT=3001

# Python executable (in container, python3 is default)
PYTHON_PATH=python3

# Server hostname (for CORS — leave blank to allow all origins in production)
# ALLOWED_ORIGIN=https://claims.yourcompany.com

# PostgreSQL
POSTGRES_USER=cap_user
POSTGRES_PASSWORD=change-me-to-a-secure-random-password
POSTGRES_DB=claim_analytics
DATABASE_URL=postgresql://cap_user:change-me-to-a-secure-random-password@db:5432/claim_analytics

# Authentication
JWT_SECRET=change-me-to-a-long-random-string-min-64-chars

# Cookie security: set to 'true' only if serving over HTTPS
# For plain HTTP (e.g. http://178.104.35.208), leave as 'false'
COOKIE_SECURE=false

# SMTP — Email verification (OTP)
# For Gmail: SMTP_HOST=smtp.gmail.com, SMTP_PORT=587, SMTP_USER=you@gmail.com, SMTP_PASS=your-app-password
# If omitted, OTPs are logged to the server console (dev mode)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM=your-email@gmail.com
