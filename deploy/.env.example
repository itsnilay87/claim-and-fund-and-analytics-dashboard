# ─────────────────────────────────────────────────────────
#  Claim Analytics Platform — Environment Variables
#  Copy to .env and adjust values for your deployment
# ─────────────────────────────────────────────────────────

# Node server
NODE_ENV=production
PORT=3001

# Python executable (in container, python3 is default)
PYTHON_PATH=python3

# Server hostname (for CORS — leave blank to allow all origins in production)
# ALLOWED_ORIGIN=https://claims.yourcompany.com
